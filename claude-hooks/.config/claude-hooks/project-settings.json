{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/claude-observer/scripts/send-event.sh idle '' SessionStart",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/claude-observer/scripts/send-event.sh working '' UserPromptSubmit",
            "timeout": 5
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/claude-observer/scripts/send-event.sh attention permission PermissionRequest && terminal-notifier -title 'Permission Needed' -message \"Approve in ${PWD##*/}\" -sound Basso || true",
            "timeout": 10
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/claude-observer/scripts/send-event.sh attention input Notification",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/claude-observer/scripts/send-event.sh idle '' Stop && terminal-notifier -title 'Claude Done' -message \"Done in ${PWD##*/}\" -sound default || true",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/claude-observer/scripts/send-event.sh working '' PreToolUse",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/claude-observer/scripts/send-event.sh working '' PostToolUse",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "rm -f ~/.cache/claude-status/pane-${WEZTERM_PANE:-unknown}.json 2>/dev/null || true",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/claude-observer/scripts/send-event.sh compacting '' PreCompact",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
