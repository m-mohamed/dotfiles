{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/mohamedmohamed/.config/claude-hooks/write-status.sh idle '' SessionStart",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/mohamedmohamed/.config/claude-hooks/write-status.sh working '' UserPromptSubmit",
            "timeout": 5
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/mohamedmohamed/.config/claude-hooks/write-status.sh attention permission PermissionRequest && terminal-notifier -title 'Permission Needed' -message \"Approve in ${PWD##*/}\" -sound Basso || true",
            "timeout": 10
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/mohamedmohamed/.config/claude-hooks/write-status.sh attention input Notification && terminal-notifier -title 'Claude Waiting' -message \"Needs input in ${PWD##*/}\" -sound Basso || true",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/mohamedmohamed/.config/claude-hooks/write-status.sh idle '' Stop && terminal-notifier -title 'Claude Done' -message \"Done in ${PWD##*/}\" -sound default || true",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/mohamedmohamed/.config/claude-hooks/write-status.sh working '' PreToolUse",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/mohamedmohamed/.config/claude-hooks/write-status.sh working '' PostToolUse",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/mohamedmohamed/.config/claude-hooks/write-status.sh working '' SubagentStop",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$(date '+%Y-%m-%d %H:%M:%S') | hook=SessionEnd cleanup pane=${WEZTERM_PANE:-unset} project=${PWD##*/}\" >> ~/.cache/claude-status/debug.log; rm -f ~/.cache/claude-status/pane-${WEZTERM_PANE:-unknown}.json 2>/dev/null || true",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/mohamedmohamed/.config/claude-hooks/write-status.sh compacting '' PreCompact && terminal-notifier -title 'Context Compacting' -message \"Compacting in ${PWD##*/}\" -sound Purr || true",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
